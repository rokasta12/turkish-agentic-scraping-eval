{
  "name": "turkish-agentic-scraping-eval",
  "version": "0.1.0",
  "description": "Executable TypeScript eval harness for safe Turkish agentic browser scraping research.",
  "type": "module",
  "scripts": {
    "eval": "tsx src/eval.ts",
    "discover:tr": "tsx src/discovery/runner.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "npm run typecheck && npm run eval && npm run discover:tr"
  },
  "keywords": [
    "playwright",
    "cheerio",
    "zod",
    "scraping",
    "browser-automation",
    "agentic-browser",
    "turkish-web",
    "eval"
  ],
  "author": "Bedirhan Celayir",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rokasta12/turkish-agentic-scraping-eval.git"
  },
  "bugs": {
    "url": "https://github.com/rokasta12/turkish-agentic-scraping-eval/issues"
  },
  "homepage": "https://github.com/rokasta12/turkish-agentic-scraping-eval#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.8.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.2.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "robots-parser": "^3.0.1",
    "zod": "^4.4.3"
  }
}
